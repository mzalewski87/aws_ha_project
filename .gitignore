# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
!*.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Cross-workspace handoff (generated by Phase 2a)
panorama_vm_auth_key.auto.tfvars

# Secrets / keys
*.pem
*.key
id_rsa*

# Rendered bootstrap copies (may contain auth codes / PINs)
**/init-cfg-*.txt
**/rendered/*

# Reference PDF library — vendor-copyrighted documents (PANW, etc.)
# Track only the catalogue / index, not the binaries.
docs/reference/pdfs/*.pdf

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Internal / assistant-only files — never publish
CLAUDE.md
NEXT-SESSION-PROMPT.md
docs/aws-research-briefing.md
