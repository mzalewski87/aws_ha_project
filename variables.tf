  type        = string
  default     = "10.21.0.0/16"
}

variable "spoke1_vpc_cidr_b" {
  description = "Region B spoke1 (app) VPC CIDR."
  type        = string
  default     = "10.22.0.0/16"
}

variable "spoke2_vpc_cidr_b" {
  description = "Region B spoke2 (DC) VPC CIDR."
  type        = string
  default     = "10.23.0.0/16"
}

variable "region_b_create_app" {
  description = "Deploy the app path (NLB/CloudFront/Apache) in Region B too."
